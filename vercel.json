{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/claude",   "dest": "/api/claude.js" },
    { "src": "/api/validate", "dest": "/api/validate.js" },
    { "src": "/api/health",   "dest": "/api/health.js" },
    { "src": "/(.*)",         "dest": "/index.html" }
  ]
}
